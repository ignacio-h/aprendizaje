@page
@{
    ViewData["Title"] = "Patterns";
}


<style>
    .app-container {
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
    }

    /* ============================================
           HEADER
           ============================================ */
    .header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1.5rem 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        .header h1 {
            font-size: 1.5rem;
        }

    /* ============================================
           LAYOUT PRINCIPAL CON GRID
           ============================================ */
    .main-layout {
        display: grid;
        grid-template-columns: 300px 1fr 250px;
        grid-template-areas: "sidebar main aside";
        gap: 1.5rem;
        padding: 2rem;
        max-width: 1600px;
        margin: 0 auto;
        width: 100%;
    }

    @@media (max-width: 1200px) {
        .main-layout {
            grid-template-columns: 250px 1fr;
            grid-template-areas: "sidebar main";
        }

        .aside {
            display: none;
        }
    }

    @@media (max-width: 768px) {
        .main-layout {
            grid-template-columns: 1fr;
            grid-template-areas: "main";
        }

        .sidebar {
            display: none;
        }
    }

    .sidebar {
        grid-area: sidebar;
    }

    .main-content {
        grid-area: main;
    }

    .aside {
        grid-area: aside;
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 1rem;
    }

    /* ============================================
           PATRÓN 1: WIDGET ADAPTATIVO
           ============================================ */

    /* Contenedor del widget con Container Query */
    .widget-container {
        container-type: inline-size;
        container-name: widget;
        margin-bottom: 1.5rem;
    }

    .widget {
        background: white;
        border-radius: 8px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        display: grid;
        gap: 1rem;
    }

    .widget-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e2e8f0;
    }

    .widget-icon {
        font-size: 2rem;
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .widget-info {
        flex: 1;
        min-width: 0;
    }

    .widget-title {
        font-size: clamp(0.9rem, 4cqw, 1.25rem);
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 0.25rem;
    }

    .widget-subtitle {
        font-size: clamp(0.75rem, 3cqw, 0.9rem);
        color: #64748b;
    }

    .widget-stats {
        display: grid;
        gap: 0.75rem;
    }

    .stat-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem;
        background: #f8fafc;
        border-radius: 6px;
    }

    .stat-label {
        font-size: clamp(0.75rem, 3cqw, 0.85rem);
        color: #64748b;
    }

    .stat-value {
        font-size: clamp(0.9rem, 4cqw, 1.1rem);
        font-weight: 700;
        color: #2563eb;
    }

    /* Layout horizontal en contenedores anchos */
    @@container widget (min-width: 450px) {
        .widget {
            grid-template-columns: auto 1fr;
        }

        .widget-header {
            grid-column: 1 / -1;
            border-bottom: none;
            padding-bottom: 0;
        }

        .widget-icon {
            width: 80px;
            height: 80px;
            font-size: 2.5rem;
        }
    }

    /* Columnas en stats cuando hay espacio */
    @@container widget (min-width: 350px) {
        .widget-stats {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@container widget (min-width: 600px) {
        .widget-stats {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    /* ============================================
           PATRÓN 2: CARD DE PRODUCTO ADAPTATIVA
           ============================================ */

    .product-container {
        container-type: inline-size;
        container-name: product;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .product-card {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        display: grid;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.15);
        }

    /* Layout vertical por defecto */
    .product-card {
        grid-template-rows: auto 1fr auto;
    }

    .product-image {
        width: 100%;
        height: 200px;
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
    }

    .product-content {
        padding: 1.5rem;
        display: grid;
        gap: 0.5rem;
    }

    .product-category {
        font-size: 0.75rem;
        color: #2563eb;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .product-title {
        font-size: clamp(1rem, 5cqw, 1.25rem);
        font-weight: 600;
        color: #1e293b;
        line-height: 1.3;
    }

    .product-description {
        font-size: clamp(0.85rem, 3.5cqw, 0.95rem);
        color: #64748b;
        line-height: 1.5;
    }

    .product-footer {
        padding: 1rem 1.5rem;
        background: #f8fafc;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .product-price {
        font-size: clamp(1.25rem, 6cqw, 1.75rem);
        font-weight: 700;
        color: #10b981;
    }

    .product-button {
        background: #2563eb;
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        font-size: clamp(0.85rem, 3.5cqw, 0.95rem);
        transition: background 0.2s;
        white-space: nowrap;
    }

        .product-button:hover {
            background: #1d4ed8;
        }

    /* Layout horizontal en contenedores muy anchos */
    @@container product (min-width: 500px) {
        .product-card {
            grid-template-columns: 200px 1fr;
            grid-template-rows: 1fr auto;
        }

        .product-image {
            grid-row: 1 / -1;
            height: 100%;
        }

        .product-footer {
            grid-column: 2;
        }
    }

    /* ============================================
           PATRÓN 3: TABLA/LISTA ADAPTATIVA
           ============================================ */

    .list-container {
        container-type: inline-size;
        container-name: list;
    }

    .data-list {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .list-item {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #e2e8f0;
        display: grid;
        gap: 0.5rem;
        transition: background 0.2s;
    }

        .list-item:hover {
            background: #f8fafc;
        }

        .list-item:last-child {
            border-bottom: none;
        }

    /* Layout apilado por defecto */
    .item-name {
        font-weight: 600;
        color: #1e293b;
        font-size: clamp(0.9rem, 4cqw, 1rem);
    }

    .item-email {
        color: #64748b;
        font-size: clamp(0.8rem, 3cqw, 0.85rem);
    }

    .item-role {
        color: #2563eb;
        font-size: clamp(0.75rem, 3cqw, 0.8rem);
        font-weight: 600;
    }

    .item-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .action-button {
        background: #e0e7ff;
        color: #3730a3;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        cursor: pointer;
        font-size: clamp(0.75rem, 3cqw, 0.85rem);
        font-weight: 500;
        transition: background 0.2s;
    }

        .action-button:hover {
            background: #c7d2fe;
        }

    /* Layout de tabla en contenedores anchos */
    @@container list (min-width: 500px) {
        .list-item {
            grid-template-columns: 2fr 2fr 1fr auto;
            align-items: center;
            gap: 1rem;
        }

        .item-actions {
            margin-top: 0;
        }
    }

    /* ============================================
           PATRÓN 4: STAT CARDS CON CRECIMIENTO
           ============================================ */

    .stat-card-container {
        container-type: inline-size;
        container-name: stat;
    }

    .stat-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border-radius: 8px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        display: grid;
        gap: 1rem;
    }

    .stat-card-icon {
        font-size: clamp(2rem, 10cqw, 3rem);
        width: clamp(50px, 20cqw, 70px);
        height: clamp(50px, 20cqw, 70px);
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stat-card-value {
        font-size: clamp(1.5rem, 8cqw, 2.5rem);
        font-weight: 700;
        color: #1e293b;
        line-height: 1;
    }

    .stat-card-label {
        font-size: clamp(0.85rem, 4cqw, 1rem);
        color: #64748b;
    }

    .stat-card-change {
        font-size: clamp(0.75rem, 3.5cqw, 0.85rem);
        font-weight: 600;
        color: #10b981;
    }

    /* Layout horizontal en stat cards anchas */
    @@container stat (min-width: 280px) {
        .stat-card {
            grid-template-columns: auto 1fr;
            grid-template-rows: auto auto auto;
        }

        .stat-card-icon {
            grid-row: 1 / -1;
        }

        .stat-card-value {
            align-self: end;
        }

        .stat-card-change {
            align-self: start;
        }
    }

    /* ============================================
           FOOTER
           ============================================ */
    .footer {
        background: #1e293b;
        color: #94a3b8;
        padding: 1.5rem 2rem;
        text-align: center;
    }

    /* ============================================
           INDICADORES VISUALES
           ============================================ */
    .container-indicator {
        position: relative;
    }

        .container-indicator::before {
            content: "📦 Container Query";
            position: absolute;
            top: -8px;
            right: -8px;
            background: #10b981;
            color: white;
            padding: 0.25rem 0.5rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 600;
            z-index: 10;
            pointer-events: none;
            opacity: 0.8;
        }

    .code-example {
        background: #1e293b;
        color: #e2e8f0;
        padding: 1rem;
        border-radius: 6px;
        font-family: 'Courier New', monospace;
        font-size: 0.85rem;
        margin-top: 1rem;
        overflow-x: auto;
    }

    .highlight {
        color: #fbbf24;
        font-weight: 600;
    }
</style>
<div class="app-container">
    <!-- HEADER -->
    <header class="header">
        <h1>🎯 Patrones Avanzados: Grid + Container Queries</h1>
        <p style="opacity: 0.9; margin-top: 0.5rem; font-size: 0.95rem;">
